<Project Sdk="Microsoft.NET.Sdk.Web">

 <PropertyGroup>
    <TargetFramework>net9.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <AssemblyName>MyAspNetStaticStarter</AssemblyName>
    <RootNamespace>TheAlloyDev.MyAspNetStaticStarter</RootNamespace>
  </PropertyGroup>

  <!-- Prevent the web project from compiling anything under tests/** -->
  <ItemGroup>
    <Compile Remove="tests\**\*.cs" />
    <EmbeddedResource Remove="tests\**\*" />
    <None Remove="tests\**\*" />
    <Content Remove="tests\**\*" />
  </ItemGroup>


</Project>